# Backend
DATABASE_URL=sqlite:data.db?mode=rwc
JWT_SECRET=replace-with-a-long-random-secret
HOST=127.0.0.1
PORT=8080

# Public URLs used for redirects, CORS, and Strava callbacks.
BASE_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
STRAVA_REDIRECT_URI=http://localhost:5173/api/strava/callback

# Strava API application credentials.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Optional LLM provider key. Leave blank to disable AI features locally.
OPENROUTER_API_KEY=

# Optional admin and quota settings.
ADMIN_STRAVA_ID=
QUOTA_MARKUP_RATIO=5.0
